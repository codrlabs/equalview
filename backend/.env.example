# Port the API listens on. Defaults to 3000.
PORT=3000

# Allowed CORS origin for the Vite dev server. Override in production.
FRONTEND_ORIGIN=http://localhost:5173

# Sessions (min 32 chars; generate with: openssl rand -base64 32)
SESSION_SECRET=

# GitHub App OAuth (Phase 1 — see backend/README.md § GitHub App setup)
# Client ID + Client secret from your GitHub App → OAuth credentials (not the numeric App ID).
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# Numeric App ID + private key (Settings → General) — required for repo writes.
# OAuth alone identifies the user; installation tokens write to installed repos.
GITHUB_APP_ID=
# Paste PEM with literal \n newlines, or point to a file:
GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/vizably-app.private-key.pem

# Token encryption at rest (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=

# Google OAuth + Picker (Phase 3 — see backend/README.md § Google OAuth setup)
# Cloud Console → APIs & Services → enable Drive API + Google Picker API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Browser API key for Google Picker (restrict by HTTP referrer). Served via GET /api/auth/config.
GOOGLE_PICKER_API_KEY=

# --- Phase 5 (planned, not yet read by the server) ----------------------
# JWT_SECRET=replace-me-with-a-long-random-string
# DATABASE_URL=postgres://user:pass@localhost:5432/vizably
